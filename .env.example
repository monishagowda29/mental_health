# .env.example — Copy this file to .env and fill in your values
# cp .env.example .env

# ── Required: Groq API Key ──────────────────────────────────────────────────
# Get a FREE key at: https://console.groq.com → Sign up → API Keys → Create
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: Override model path ───────────────────────────────────────────
# Default: models/bert_mental_health (relative to project root)
# MODEL_DIR=models/bert_mental_health

# ── Optional: Force device ──────────────────────────────────────────────────
# Auto-detected. Override only if you need to force CPU on a GPU machine.
# DEVICE=cpu

# ── Optional: Hugging Face translation model ────────────────────────────────
# HF_TRANSLATION_MODEL=Helsinki-NLP/opus-mt-mul-en

# ── Optional: Groq vision model ─────────────────────────────────────────────
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Optional: Debug logging ──────────────────────────────────────────────────
# DEBUG=False
